{
  "expo": {
    "name": "Time2Pay",
    "slug": "time2pay",
    "version": "1.0.0",
    "userInterfaceStyle": "automatic",
    "orientation": "portrait",
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://lucid-lewin.108-175-12-95.plesk.page",
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "web": {
      "bundler": "metro",
      "output": "server"
    }
  }
}
