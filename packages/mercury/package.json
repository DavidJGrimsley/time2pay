{
  "name": "@mrdj/mercury",
  "version": "0.1.0",
  "description": "Incubating Mercury API SDK for Time2Pay",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "license": "MIT"
}
