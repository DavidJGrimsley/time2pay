{
  "name": "time2pay",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "icons:sync": "node scripts/copy-icons.mjs",
    "build:web": "npm run icons:sync && expo export -p web && node scripts/generate-sw.mjs",
    "serve:prod": "node server.js",
    "serve:prod:env": "node --env-file=.env server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "doctor": "npx expo-doctor"
  },
  "dependencies": {
    "@react-native-picker/picker": "2.11.4",
    "compression": "^1.8.1",
    "expo": "~55.0.5",
    "expo-constants": "~55.0.7",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.4",
    "expo-server": "~55.0.6",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "express": "^5.2.1",
    "morgan": "^1.10.1",
    "pdf-lib": "^1.17.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-ui-datepicker": "^3.1.2",
    "react-native-web": "^0.21.0",
    "tailwindcss": "^4.1.16",
    "uniwind": "^1.2.9"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "eslint": "^9.39.3",
    "eslint-config-expo": "~55.0.0",
    "typescript": "~5.9.2",
    "workbox-build": "^7.4.0"
  }
}
