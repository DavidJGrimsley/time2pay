# Mercury API configuration (server-side required key).
# Do not prefix these with EXPO_PUBLIC_.
MERCURY_API_KEY=replace-with-your-mercury-api-key
MERCURY_ENVIRONMENT=production
MERCURY_BASE_URL=https://api.mercury.com/api/v1

# Mercury contract tests (test environment only)
# Set MERCURY_CONTRACT_RUN=true to enable:
# npm run test:mercury:contract
MERCURY_CONTRACT_RUN=false
MERCURY_SANDBOX_API_KEY=replace-with-your-mercury-test-api-key
MERCURY_SANDBOX_BASE_URL=https://api-sandbox.mercury.com/api/v1
MERCURY_CONTRACT_AR_ENABLED=false
MERCURY_CONTRACT_DESTINATION_ACCOUNT_ID=
MERCURY_CONTRACT_TRANSFER_PAYLOAD_JSON=
MERCURY_CONTRACT_SEND_MONEY_ACCOUNT_ID=
MERCURY_CONTRACT_SEND_MONEY_PAYLOAD_JSON=

# GitHub OAuth configuration (optional for Sign in with GitHub).
# Server-side secret values:
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
#
# Client-visible id used by web UI to show OAuth button:
EXPO_PUBLIC_GITHUB_CLIENT_ID=
