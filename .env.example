# Mercury API configuration (server-side required key).
# Do not prefix these with EXPO_PUBLIC_.
MERCURY_API_KEY=replace-with-your-mercury-api-key
MERCURY_ENVIRONMENT=production
MERCURY_BASE_URL=https://api.mercury.com/api/v1

# Mercury contract tests (test environment only)
# Set MERCURY_CONTRACT_RUN=true to enable:
# npm run test:mercury:contract
MERCURY_CONTRACT_RUN=false
MERCURY_SANDBOX_API_KEY=replace-with-your-mercury-test-api-key
MERCURY_SANDBOX_BASE_URL=https://api-sandbox.mercury.com/api/v1
MERCURY_CONTRACT_AR_ENABLED=false
MERCURY_CONTRACT_DESTINATION_ACCOUNT_ID=
MERCURY_CONTRACT_TRANSFER_PAYLOAD_JSON=
MERCURY_CONTRACT_SEND_MONEY_ACCOUNT_ID=
MERCURY_CONTRACT_SEND_MONEY_PAYLOAD_JSON=

# GitHub OAuth configuration (optional for Sign in with GitHub).
# Server-side secret values:
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
#
# Client-visible id used by web UI to show OAuth button:
EXPO_PUBLIC_GITHUB_CLIENT_ID=

# Runtime data mode:
# - local: existing expo-sqlite workflow (default)
# - hosted: Supabase Auth + Postgres workflow
EXPO_PUBLIC_TIME2PAY_DATA_MODE=local

# Supabase hosted mode (required when EXPO_PUBLIC_TIME2PAY_DATA_MODE=hosted)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Alias accepted by app runtime as well:
EXPO_PUBLIC_SUPABASE_KEY=
# Optional auth redirect override for magic-link + OAuth:
# - URL wins if set (recommended for production): https://time2pay.app/dashboard
# - path fallback is used against current window origin (default: /dashboard)
EXPO_PUBLIC_SUPABASE_AUTH_REDIRECT_URL=
EXPO_PUBLIC_SUPABASE_AUTH_REDIRECT_PATH=/dashboard
SUPABASE_SERVICE_ROLE_KEY=
# Pooled connection (usually port 6543). Drizzle CLI uses this by default.
DATABASE_URL=
# Direct connection (usually port 5432). Use only if your network supports it.
DATABASE_DIRECT_URL=
# Optional explicit Drizzle URL override for migrations/checks.
# Precedence: DRIZZLE_DATABASE_URL -> DATABASE_URL -> DATABASE_DIRECT_URL.
DRIZZLE_DATABASE_URL=
